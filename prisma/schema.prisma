// MatchVenture — Prisma schema (MySQL)
// v0.1 covers self-contained auth (User + refresh tokens + OTP).
// Domain tables (profiles, swipes, unlocks, matches, subscriptions, quota_ledger)
// are added in later milestones — see PITCHMATCH_BUILD_CHECKLIST.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  INVESTOR
  INNOVATOR
  MEDIATOR
  ADMIN
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DELETED
}

enum OtpChannel {
  EMAIL
  PHONE
}

enum OtpPurpose {
  REGISTRATION
  LOGIN
  PASSWORD_RESET
}

model User {
  id            String     @id @default(cuid())
  role          Role
  name          String     @db.VarChar(120)
  email         String     @unique
  phone         String     @unique
  passwordHash  String     @map("password_hash")
  country       String?
  city          String?
  photoUrl      String?    @map("photo_url")
  linkedinUrl   String?    @map("linkedin_url")
  bio           String?    @db.VarChar(300)
  emailVerified    Boolean    @default(false) @map("email_verified")
  phoneVerified    Boolean    @default(false) @map("phone_verified")
  profileCompleted Boolean    @default(false) @map("profile_completed")
  status           UserStatus @default(PENDING_VERIFICATION)
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  refreshTokens    RefreshToken[]
  otpCodes         OtpCode[]
  investorProfile  InvestorProfile?
  innovatorProfile InnovatorProfile?
  mediatorProfile  MediatorProfile?
  swipesMade       Swipe[]           @relation("swiper")
  swipesReceived   Swipe[]           @relation("target")
  matchesA         Match[]           @relation("matchA")
  matchesB         Match[]           @relation("matchB")
  sentMessages     Message[]
  blocksMade       Block[]           @relation("blocker")
  blocksReceived   Block[]           @relation("blocked")
  reportsMade      Report[]          @relation("reporter")
  reportsReceived  Report[]          @relation("reported")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model OtpCode {
  id         String     @id @default(cuid())
  userId     String     @map("user_id")
  channel    OtpChannel
  purpose    OtpPurpose @default(REGISTRATION)
  codeHash   String     @map("code_hash")
  expiresAt  DateTime   @map("expires_at")
  consumedAt DateTime?  @map("consumed_at")
  attempts   Int        @default(0)
  createdAt  DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("otp_codes")
}

// ---- Profiles ----
// Multi-select fields (sectors, stages, geo, jurisdictions, specializations) are
// stored as JSON arrays of strings (MySQL JSON) so the matching engine can use
// JSON_OVERLAPS. Single-select fields use enums.

enum InvestorType {
  ANGEL
  VC
  FAMILY_OFFICE
  CORPORATE
  INDIVIDUAL
}

enum FundingBracket {
  B_5K_25K
  B_25K_100K
  B_100K_500K
  B_500K_2M
  B_2M_PLUS
}

enum InnovatorStage {
  IDEA
  PROTOTYPE
  REVENUE_GENERATING
  SCALING
}

enum BusinessModel {
  B2B
  B2C
  B2B2C
  MARKETPLACE
  SUBSCRIPTION
  OTHER
}

enum Instrument {
  EQUITY
  SAFE
  CONVERTIBLE_NOTE
  REVENUE_SHARE
  OPEN_TO_DISCUSS
}

enum FeeModel {
  HOURLY
  FIXED_PER_DEAL
  SUCCESS_FEE
}

enum MediatorVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model InvestorProfile {
  userId       String         @id @map("user_id")
  investorType InvestorType   @map("investor_type")
  sectors      Json // string[]
  stages       Json // string[] (Idea/Pre-seed/Seed/Series A/Growth)
  ticketMin    FundingBracket @map("ticket_min")
  ticketMax    FundingBracket @map("ticket_max")
  geoFocus     Json           @map("geo_focus") // string[] or ["GLOBAL"]
  horizon      String? // <1yr / 1-3yrs / 3-5yrs / 5+yrs
  involvement  String? // Silent / Advisory / Board seat / Hands-on
  coInvest     Boolean?       @map("co_invest")
  dealsCount   Int?           @map("deals_count")
  verifiedBadge Boolean       @default(false) @map("verified_badge")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("investor_profiles")
}

model InnovatorProfile {
  userId          String         @id @map("user_id")
  title           String
  sector          String
  stage           InnovatorStage
  oneLiner        String         @map("one_liner") @db.VarChar(140)
  problem         String         @db.VarChar(600)
  solution        String         @db.VarChar(1000)
  businessModel   BusinessModel  @map("business_model")
  fundingMin      FundingBracket @map("funding_min")
  fundingMax      FundingBracket @map("funding_max")
  instrument      Instrument
  breakevenMonths Int?           @map("breakeven_months")
  revY1           String?        @map("rev_y1")
  revY2           String?        @map("rev_y2")
  revY3           String?        @map("rev_y3")
  traction        String?        @db.VarChar(500)
  geoMarket       Json           @map("geo_market") // string[]
  deckUrl         String?        @map("deck_url")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("innovator_profiles")
}

model MediatorProfile {
  userId             String                     @id @map("user_id")
  profTitle          String                     @map("prof_title")
  qualification      String
  licenseNo          String                     @map("license_no")
  licenseBody        String                     @map("license_body")
  jurisdictions      Json // string[]
  yearsExp           Int                        @map("years_exp")
  specializations    Json // string[]
  firm               String?
  feeModel           FeeModel                   @map("fee_model")
  feeRange           String?                    @map("fee_range")
  verificationStatus MediatorVerificationStatus @default(PENDING) @map("verification_status")
  verifiedAt         DateTime?                  @map("verified_at")
  verifiedBy         String?                    @map("verified_by")
  rejectionReason    String?                    @map("rejection_reason")
  createdAt          DateTime                   @default(now()) @map("created_at")
  updatedAt          DateTime                   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mediator_profiles")
}

// ---- Discovery ----

enum SwipeDirection {
  LEFT
  RIGHT
}

enum MatchStatus {
  ACTIVE
  BLOCKED
  CLOSED
}

model Swipe {
  id        String         @id @default(cuid())
  swiperId  String         @map("swiper_id")
  targetId  String         @map("target_id")
  direction SwipeDirection
  createdAt DateTime       @default(now()) @map("created_at")

  swiper User @relation("swiper", fields: [swiperId], references: [id], onDelete: Cascade)
  target User @relation("target", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([swiperId, targetId])
  @@index([targetId])
  @@map("swipes")
}

model Match {
  id        String      @id @default(cuid())
  userAId   String      @map("user_a")
  userBId   String      @map("user_b")
  status    MatchStatus @default(ACTIVE)
  matchedAt DateTime    @default(now()) @map("matched_at")

  userA User @relation("matchA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("matchB", fields: [userBId], references: [id], onDelete: Cascade)

  conversation Conversation?

  @@unique([userAId, userBId])
  @@index([userBId])
  @@map("matches")
}

// ---- Chat ----

enum ConversationType {
  MATCH
  DEAL_ROOM
}

model Conversation {
  id         String           @id @default(cuid())
  matchId    String           @unique @map("match_id")
  type       ConversationType @default(MATCH)
  mediatorId String?          @map("mediator_id")
  createdAt  DateTime         @default(now()) @map("created_at")

  match    Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("conversations")
}

model Message {
  id             Int       @id @default(autoincrement())
  conversationId String    @map("conversation_id")
  senderId       String    @map("sender_id")
  body           String    @db.Text
  attachmentUrl  String?   @map("attachment_url")
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

// ---- Safety ----

enum ReportReason {
  SPAM
  INAPPROPRIATE
  SCAM
  FAKE_PROFILE
  HARASSMENT
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  ACTIONED
  DISMISSED
}

model Block {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

model Report {
  id         String       @id @default(cuid())
  reporterId String       @map("reporter_id")
  reportedId String       @map("reported_id")
  reason     ReportReason
  details    String?      @db.VarChar(1000)
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now()) @map("created_at")

  reporter User @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User @relation("reported", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([reportedId])
  @@map("reports")
}
