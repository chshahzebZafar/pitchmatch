# Copy to .env for local development. .env is gitignored — never commit real values.
# On Hostinger these are set in hPanel -> Node.js app -> Environment variables,
# not in a file.

# --- Database -----------------------------------------------------------
# NOTE: must be 127.0.0.1, not localhost — the MySQL user is granted for the
# IP form only, and `localhost` fails auth (P1000) for every password.
DATABASE_URL="mysql://user:password@127.0.0.1:3306/dbname"

# --- App ----------------------------------------------------------------
PORT=3000
API_PREFIX=api/v1

# --- JWT ----------------------------------------------------------------
JWT_ACCESS_SECRET=change_me
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change_me_too
JWT_REFRESH_TTL=30d

# --- OTP ----------------------------------------------------------------
OTP_TTL_SECONDS=300
OTP_LENGTH=6

# --- Mail (SMTP) --------------------------------------------------------
# Leave SMTP_USER/SMTP_PASS empty to disable sending: codes are logged to the
# server console instead, which is what local dev normally wants.
#
# Gmail: requires 2-Step Verification plus a 16-character App Password. Your
# normal account password is always rejected. Free accounts cap at ~500/day.
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#
# Domain mailbox (preferred for production — better deliverability, no cap,
# and less likely to be blocked outbound since it is on the same network):
#   SMTP_HOST=smtp.hostinger.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#
# If 465 times out, try SMTP_PORT=587 with SMTP_SECURE=false (STARTTLS).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_REPLY_TO=
MAIL_APP_NAME=PitchMatch

# --- Uploads ------------------------------------------------------------
# Sibling of the app dir so redeploys don't wipe user uploads.
# UPLOAD_DIR=/home/<user>/domains/<domain>/uploads
