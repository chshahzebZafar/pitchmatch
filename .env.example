# ---- App ----
NODE_ENV=production
PORT=3000
API_PREFIX=api/v1
# Comma-separated allowed origins for CORS, or * for all (tighten in prod)
CORS_ORIGINS=*

# ---- Database (Hostinger MySQL) ----
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://pitchmatch:password@localhost:3306/pitchmatch"

# ---- JWT ----
# Generate strong random values, e.g.  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_long_random_string
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_REFRESH_TTL=30d

# ---- OTP ----
OTP_TTL_SECONDS=300
OTP_LENGTH=6

# ---- Bootstrap admin (used by: npm run db:seed:admin) ----
ADMIN_EMAIL=admin@pitchmatch.app
ADMIN_PHONE=+10000000000
ADMIN_PASSWORD=ChangeMeStrong!123
ADMIN_NAME=PitchMatch Admin
